---
// src/pages/transparency.astro

import moment from 'moment'

import MainLayout from '../layouts/MainLayout.astro'
import Section from '../components/sections/Section.astro'
import '../styles/globals.css'
---

<MainLayout
      title="Transparency — Ava's DAO"
      description="Ava Nakamoto showcases her life's work in a DAO that carries on where her father left off in 2010."
>
    <Section>
        <div class="mt-[135px]" />

        <header class="sm:px-3 text-rose-600 font-medium tracking-widest opacity-50">
            <h1 class="text-3xl sm:text-4xl uppercase">
                Ava's DAO
            </h1>

            <h1 class="text-4xl sm:text-6xl uppercase">
                Transparency
            </h1>

            <h3 class="text-lg sm:text-2xl">
                {moment().format('MMMM YYYY')}
            </h3>
        </header>

        <section class="px-5 sm:px-8 my-8 py-6 bg-gradient-to-br from-rose-50 to-white rounded-2xl border border-rose-100 shadow-sm">
            <h3 class="text-2xl text-rose-700 font-bold flex items-center gap-2">
                <span class="inline-block w-2 h-2 rounded-full bg-rose-500"></span>
                Don't Trust. Verify!
            </h3>

            <p class="mt-3 text-base text-gray-600 italic leading-relaxed">
                Ava is well-respected for her natural ability to lead by example.
                Her DAO has committed to FULL transparency to its community by utilizing the on-chain financial &amp; data capabilities of blockchain-based networks & services in 100% of its activities.
            </p>
        </section>

        <section class="px-5 sm:px-8 my-8">
            <h2 class="text-xl sm:text-2xl text-rose-800 font-semibold tracking-wide uppercase mb-4">
                State of the DAO Annual Reports
            </h2>

            <ol class="pl-0 list-none leading-9 space-y-3">
                <li>
                    <a href="/posts/state-of-the-dao-2023" class="group flex items-center gap-3 px-5 py-3 bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-rose-300 transition-all duration-200">
                        <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-rose-100 text-rose-600 font-bold text-sm group-hover:bg-rose-200 transition-colors">
                            '23
                        </span>
                        <span class="text-gray-800 group-hover:text-rose-600 font-medium transition-colors">
                            Ava's DAO 2023
                        </span>
                        <span class="ml-auto text-gray-300 group-hover:text-rose-400 transition-colors">
                            →
                        </span>
                    </a>
                </li>

                <li>
                    <a href="/posts/state-of-the-dao-2024" class="group flex items-center gap-3 px-5 py-3 bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md hover:border-rose-300 transition-all duration-200">
                        <span class="flex items-center justify-center w-10 h-10 rounded-lg bg-rose-100 text-rose-600 font-bold text-sm group-hover:bg-rose-200 transition-colors">
                            '24
                        </span>
                        <span class="text-gray-800 group-hover:text-rose-600 font-medium transition-colors">
                            Ava's DAO 2024
                        </span>
                        <span class="ml-auto text-gray-300 group-hover:text-rose-400 transition-colors">
                            →
                        </span>
                    </a>
                </li>
            </ol>
        </section>

